<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradient must be properly closed -->
    <gradient
        android:startColor="#0A111B"
        android:centerColor="#101823"
        android:endColor="#1A2230"
        android:angle="45"
        android:type="linear" />

    <!-- Rounded corners -->
    <corners android:radius="20dp" />

    <!-- Optional border -->
    <stroke
        android:width="5dp"
        android:color="#A48D61" />

</shape>
