<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Gradient must be properly closed -->
    <gradient
        android:startColor="#8B0000"
        android:centerColor="#FF1744"
        android:endColor="#FF6F00"
        android:angle="45"
        android:type="linear" />

    <!-- Rounded corners -->
    <corners android:radius="20dp" />

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#AAFFFFFF" />

</shape>
