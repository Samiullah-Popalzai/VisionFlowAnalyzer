<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="0dp">

    <!-- Top-right green circle with check -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        >

        <View
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:background="@drawable/circle_bg"
            android:layout_gravity="bottom|end"
            android:translationX="100dp"
            android:translationY="0dp"/>


        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:translationX="50dp"
            android:translationY="0dp"
            >

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/small_circle"
                android:src="@drawable/thick" />

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/thick"
                android:layout_gravity="center"
                />

        </FrameLayout>

    </FrameLayout>







    <!-- Success Message -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Congratulations,\nyour app has been successfully activated!"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/themecolor"
        android:gravity="start"
        android:layout_marginTop="50dp"
        android:layout_gravity="start"
        android:paddingStart="30dp"
        />

    <!-- Subtitle -->
    <TextView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="Your license is valid and ready to use."
        android:textSize="20sp"
        android:textColor="@color/textcolor"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"
        android:layout_gravity="start"
        android:paddingStart="30dp"
        />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        >
        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRunAnalyzer"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:text="Run Analyzer"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@android:color/white"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeLicense"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:text="Change License"
            android:textColor="@android:color/black"
            android:layout_marginBottom="16dp"
            app:backgroundTint="@android:color/white"
            app:strokeColor="@android:color/black"
            app:strokeWidth="2dp"
            app:cornerRadius="8dp" />


    </LinearLayout>


</LinearLayout>
