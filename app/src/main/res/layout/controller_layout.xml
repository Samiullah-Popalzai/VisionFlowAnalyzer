<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/layout_border"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="0dp">

        <!-- Logo at start -->
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/proicon"
            android:layout_gravity="start" />

        <!-- Text centered in remaining space -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/powered_by_maher"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginLeft="30dp"
            android:gravity="center" />
    </LinearLayout>


    <!-- Size Controller -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center"
        >
        <!-- Slider for rectangle size -->
        <TextView
            android:id="@+id/rectSizeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rectangle Size: 350"
            android:textColor="#ffff"
            android:paddingTop="8dp" />

        <SeekBar
            android:id="@+id/rectSizeSeekBar"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:max="600"
            android:thumbTint="#A48D61"
            android:progressTint="#A48D61"
            android:progress="350" />
    </LinearLayout>

    <!-- Controller Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        >

        <!-- Horizontal Scroll for buttons -->
        <HorizontalScrollView
            android:id="@+id/buttonScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/progressLayout"
            android:fillViewport="true"
            android:foregroundGravity="center"
            android:scrollbars="horizontal">

            <LinearLayout
                android:id="@+id/buttonLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Start Button -->


                <!-- Close Button -->
                <ImageView
                    android:id="@+id/btnStart"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:background="@drawable/starticon"
                    android:foregroundGravity="center"
                    android:layout_marginHorizontal="10dp"
                    />

                <ImageView
                    android:id="@+id/btnClose"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/closeicon"
                    android:layout_gravity="center"
                    android:foregroundGravity="center"
                    android:layout_marginHorizontal="10dp"
                    />


                <!-- Disable Touch Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnToggleTouch"
                    android:layout_width="160dp"
                    android:layout_height="30dp"
                    android:layout_marginVertical="2dp"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:background="@drawable/button_style"
                    android:text="Disable Touch"
                    android:textColor="@color/color_white"
                    android:textSize="13sp"
                    android:layout_marginHorizontal="10dp"
                    android:textStyle="bold" />



            </LinearLayout>
        </HorizontalScrollView>

        <!-- Circular progress at top-right -->
        <FrameLayout
            android:id="@+id/progressLayout"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginStart="0dp">

            <ProgressBar
                android:id="@+id/circularProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="30"
                android:progress="30"
                android:progressDrawable="@drawable/circular_progress_bar" />

            <TextView
                android:id="@+id/progressText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="30"
                android:textColor="#00FFFFFF"
                android:textSize="0sp" />
        </FrameLayout>
    </RelativeLayout>



    <!-- Options Section -->
    <HorizontalScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="horizontal"
        android:padding="8dp">
        <!-- Container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="5dp"
            >
            <!-- Best Option -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/Option0"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/button_style"
                android:gravity="start|center_vertical"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="@string/best"
                android:textColor="@color/color_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Logical Option -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/Option1"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/button_style"
                android:gravity="start|center_vertical"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="@string/strong"
                android:textColor="@color/color_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Safe Option -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/Option2"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/button_style"
                android:gravity="start|center_vertical"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="@string/safe"
                android:textColor="@color/color_white"
                android:textSize="15sp"
                android:textStyle="bold" />
            <!-- Wildcard Options -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/Option3"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/button_style"
                android:gravity="start|center_vertical"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="@string/wildcard"
                android:textColor="@color/color_white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </HorizontalScrollView>



</LinearLayout>
